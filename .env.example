# ═══════════════════════════════════════════════════
# GenZ TV — Cloudflare Pages Environment Variables
# ═══════════════════════════════════════════════════
# Set these in the Cloudflare Dashboard → Pages → Settings → Environment Variables

# ── D1 Database (binding name: DB) ──
# Configured in wrangler.toml — no DATABASE_URL needed
# D1 binding is automatic when deployed to Cloudflare Pages
# For LOCAL DEV: set DATABASE_URL to a local SQLite file
DATABASE_URL=file:./dev.db

# ── Admin Authentication ──
ADMIN_PASSWORD=your_admin_password_here

# ── Web Push VAPID Keys ──
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here
VAPID_SUBJECT=mailto:your@email.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# ── Cron Security ──
# Used by external cron services (cron-job.org)
CRON_SECRET=your_cron_secret_here

# ── Optional ──
# NEXT_PUBLIC_GA4_MEASUREMENT_ID=
